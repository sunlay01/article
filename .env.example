# Copy this file to .env on each device and fill in your local values.
# Keep .env private and commit only .env.example.

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
# Recommended starting point from the current OpenAI models docs.
OPENAI_MODEL=gpt-5.5
OPENAI_CLASSIFY_MODEL=gpt-5.5

# Path to the system prompt file loaded by your app or script.
SYSTEM_PROMPT_PATH=prompts/research_system_prompt_en.md

# Optional locale preference for your own tooling.
USER_LANGUAGE=zh-CN
